# ─── MikroTik RouterOS API Credentials (NOC) ────────────────────────────────
MIKROTIK_USER=your_noc_username
MIKROTIK_PASS=your_noc_password

# ─── MikroTik Router Host Detection ──────────────────────────────────────────
# Default: otomatis ambil default gateway dari komputer yang menjalankan app.
# Opsional: override port REST API router jika bukan 8080.
MIKROTIK_PORT=8080
# Opsional darurat: paksa host spesifik (contoh 192.168.50.1:8080)
# MIKROTIK_HOST_FORCE=

# ─── SNMP (for lightweight periodic metrics) ─────────────────────────────────
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT_MS=2500
SNMP_RETRIES=1

# ─── Telegram Alerting ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=your-strong-random-secret-here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Health Check Interval (ms) ──────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30000

# ─── Heartbeat (CGNAT push monitoring) ───────────────────────────────────────
# Toleransi status DOWN (detik). Gunakan 60 detik (1 menit).
HEARTBEAT_TIMEOUT_SECONDS=60
# Interval checker status heartbeat di server (ms)
HEARTBEAT_MONITOR_INTERVAL_MS=10000
# Opsional: set URL publik agar endpoint pada UI sesuai domain reverse proxy
# HEARTBEAT_PUBLIC_BASE_URL=https://domainkamu.com
# Opsional: pakai secret tetap. Jika kosong, aplikasi akan generate otomatis.
HEARTBEAT_SECRET=replace_with_long_random_secret
